{
  "name": "my-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:migrate": "node-pg-migrate up -m db/migrations",
    "db:migrate:down": "node-pg-migrate down -m db/migrations",
    "db:migrate:create": "node-pg-migrate create -m db/migrations --timestamp"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1048.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.31",
    "lucide-react": "^0.576.0",
    "next-themes": "^0.4.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
