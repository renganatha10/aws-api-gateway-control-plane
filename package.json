{
  "name": "my-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "node --import ./instrument-hook.mjs --import ./instrument.server.mjs ./node_modules/.bin/react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:migrate": "node-pg-migrate up -m db/migrations",
    "db:migrate:down": "node-pg-migrate down -m db/migrations",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome lint app tests db",
    "format": "biome format --write app tests db",
    "check": "biome check app tests db",
    "check:fix": "biome check --write app tests db"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1051.0",
    "@aws-sdk/client-api-gateway": "^3.1048.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1049.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.218.0",
    "@opentelemetry/instrumentation-pino": "^0.64.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.31",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.576.0",
    "next-themes": "^0.4.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  }
}
