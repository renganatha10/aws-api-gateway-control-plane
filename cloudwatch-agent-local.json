{
  "agent": {
    "run_as_user": "renga",
    "logfile": "/tmp/amazon-cloudwatch-agent.log",
    "debug": false
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/renga/logs/api-portal/out.log",
            "log_group_name": "/api-portal/local",
            "log_stream_name": "stdout",
            "timestamp_format": "%Y-%m-%d %H:%M:%S %z",
            "timezone": "UTC",
            "multi_line_start_pattern": "^\\d{4}-\\d{2}-\\d{2}"
          },
          {
            "file_path": "/home/renga/logs/api-portal/error.log",
            "log_group_name": "/api-portal/local",
            "log_stream_name": "stderr",
            "timestamp_format": "%Y-%m-%d %H:%M:%S %z",
            "timezone": "UTC",
            "multi_line_start_pattern": "^\\d{4}-\\d{2}-\\d{2}"
          }
        ]
      }
    },
    "log_stream_name": "fallback",
    "force_flush_interval": 5
  }
}
