# Copy this to .env and fill in your values
SESSION_SECRET=change-me-to-a-random-string

# App database — matches docker-compose app-db service defaults
DATABASE_URL=postgresql://app:app_password@localhost:5432/app

# Amazon Cognito — create a User Pool + App Client in the AWS console
# App Client must have ALLOW_USER_PASSWORD_AUTH auth flow enabled
COGNITO_USER_POOL_ID=us-east-1_xxxxxxx
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_CLIENT_SECRET=your-app-client-secret

# AWS credentials (also used for API Gateway SDK)
# AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY must be set
