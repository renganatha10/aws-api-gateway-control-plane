# Copy this to .env and fill in your values
SESSION_SECRET=change-me-to-a-random-string

# App database — matches docker-compose app-db service defaults
DATABASE_URL=postgresql://app:app_password@localhost:5432/app

# Keycloak — matches docker-compose defaults when running locally
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=my-app
KEYCLOAK_CLIENT_ID=my-app-client
# Leave blank if client has no secret (public client)
KEYCLOAK_CLIENT_SECRET=

# Used server-side to create users via admin REST API
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
