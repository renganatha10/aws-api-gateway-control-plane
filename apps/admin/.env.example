# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── App ───────────────────────────────────────────────────────────────────────

SESSION_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────

# Matches the docker-compose app-db service defaults
DATABASE_URL=postgresql://app:app_password@localhost:5432/app

# ── AWS ───────────────────────────────────────────────────────────────────────

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Amazon Cognito ────────────────────────────────────────────────────────────
# Deploy infra/cognito.yaml and copy the stack outputs here.
# App Client must have ALLOW_USER_PASSWORD_AUTH auth flow enabled.

COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_CLIENT_SECRET=your-app-client-secret

# Full ARN of the User Pool — injected into every API spec as the CognitoAuth authorizer.
# Format: arn:aws:cognito-idp:<region>:<account-id>:userpool/<pool-id>
COGNITO_USER_POOL_ARN=arn:aws:cognito-idp:ap-south-1:123456789012:userpool/ap-south-1_XXXXXXXXX

# ── API Gateway logging ───────────────────────────────────────────────────────
# CloudWatch log group ARN for API Gateway access logs.
# If unset, access logging is skipped but execution logging (INFO) is still enabled.
# Format: arn:aws:logs:<region>:<account-id>:log-group:<log-group-name>
APIGW_ACCESS_LOG_GROUP_ARN=arn:aws:logs:ap-south-1:123456789012:log-group:api-gw-access-logs

# ── GoDaddy DNS ───────────────────────────────────────────────────────────────
# Used to set CNAME records automatically when creating custom domains.
# If these are not set, CNAME updates are skipped and must be done manually.
# The root domain (e.g. example.com) is provided per-domain in the New Domain form,
# not as an environment variable.
# Get your API key and secret from https://developer.godaddy.com/keys

GODADDY_KEY=your-godaddy-api-key
GODADDY_SECRET=your-godaddy-api-secret
